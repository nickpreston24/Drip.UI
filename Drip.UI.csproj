<Project Sdk="Microsoft.NET.Sdk.Razor">


  <PropertyGroup>
    <!-- Enable visible generated files -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>obj/Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>


  <ItemGroup>
    <!-- TEMPORARY BROAD FILTER FOR DEBUGGING -->
    <AdditionalFiles Include="**/*"/>
  </ItemGroup>

  <ItemGroup>
    <!-- Tell the generator where your Pines components live -->
    <AdditionalFiles Include="Components/Pines/**"/>
    <AdditionalFiles Include="Components/Pines/**/*.html"/>
    <AdditionalFiles Include="Components/Pines/**/*.pines.html"/>
  </ItemGroup>

  <ItemGroup>
    <!-- Reference the Source Generator -->
    <ProjectReference Include="..\Drip.UI.SourceGen\Drip.UI.SourceGen.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"/>
  </ItemGroup>


