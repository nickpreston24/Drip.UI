<Project Sdk="Microsoft.NET.Sdk.Razor">


  <PropertyGroup>
    <!-- Enable visible generated files -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>obj/Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <!-- Tell the generator where your Pines components live -->
    <!--    <AdditionalFiles Include="Components/Pines/**" />-->
    <AdditionalFiles Include="Components/Pines/**/*.html"/>
    <!--    <AdditionalFiles Include="Components/Pines/**/*.pines.html"/>-->
  </ItemGroup>

  <ItemGroup>
    <!-- Reference the Source Generator -->
    <ProjectReference Include="..\Drip.UI.SourceGen\Drip.UI.SourceGen.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false"/>
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
  </PropertyGroup>

  <ItemGroup>
    <Content Remove="nuget.config"/>
    <None Remove="nuget.config"/>
  </ItemGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser"/>
    <FrameworkReference Include="Microsoft.AspNetCore.App"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CodeMechanic.Logging" Version="1.0.3"/>
    <PackageReference Include="CodeMechanic.Razorhat" Version="1.0.2"/>
    <PackageReference Include="CodeMechanic.Types" Version="1.0.20"/>
    <!--    <PackageReference Include="Drip.UI.SourceGen" Version="1.0.0"-->
    <!--                      PrivateAssets="all"-->
    <!--                      ExcludeAssets="runtime"-->
    <!--    />-->
    <PackageReference Include="Hydro" Version="1.3.0"/>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="8.0.5"/>
  </ItemGroup>

